using DatabaseApp.Attributes;
using System;
using System.Collections.Generic;
using System.Web.Mvc;

namespace DatabaseApp.Controllers
{
    [CustomAuthorize]
    public class HomeController : Controller
    {
        public ActionResult Index()
        {
            return View();
        }

        [HttpPost]
        [NegativeIdActionFilter]
        [HandleError(ExceptionType = typeof(FormatException), View = "FormatError")]
        [CustomArgumentException]
        public ActionResult Index(
            int? id,
            string courseName,
            string teacher,
            int hours,
            DateTime startDate,
            decimal price)
        {
            if (id != null)
            {
                ViewBag.Id = id;
                ViewBag.CourseName = courseName;
                ViewBag.Teacher = teacher;

                ViewBag.Hours = Request.Form["hours"];
                ViewBag.StartDate = Request.Form["startDate"];
                ViewBag.Price = Request.Form["price"];

                return View("Result");
            }
            else
            {
                return RedirectToRoute(
                    "Default",
                    new
                    {
                        controller = "Home",
                        action = "Index"
                    });
            }
        }
    }
}
